@app.get("/health", tags=["System"])
def health_check():
    return {
        "status": "ok",
        "version": "1.0.0",
        "current_cpi": CURRENT_CPI,
        "current_month": CURRENT_MONTH,
        "data_years": list(CPI_DATA.keys()),
        "time": datetime.utcnow().isoformat(),
    }


@app.get("/v1/purchasing-power", tags=["Purchasing Power"])
def purchasing_power(
    amount: float = Query(..., description="Original dollar amount", gt=0),
    year: int = Query(..., description="Year the amount was from (1913-2025)", ge=1913, le=2025),
    to_year: int = Query(2026, description="Target year to adjust to", ge=1913, le=2026),
):
    """
    Calculate what an amount from one year is worth in another year's dollars.
    Example: /v1/purchasing-power?amount=1000000&year=2013&to_year=2026
    """
    return inflation_adjust(amount, year, to_year)


@app.get("/v1/wealth-erosion", tags=["Wealth Simulator"])
def wealth_erosion(
    principal: float = Query(..., description="Initial investment amount", gt=0),
    years: int = Query(..., description="Number of years to simulate", ge=1, le=50),
    asset_class: str = Query(
        "stocks_sp500",
        description="Asset class to simulate",
    ),
    inflation_scenario: str = Query(
        "official_cpi",
        description="Inflation scenario to use",
    ),
):
    """
    Compare nominal vs. real (inflation-adjusted) returns for various asset classes.
    See how much of your wealth is really "eroding" in purchasing power.
    Example: /v1/wealth-erosion?principal=1000000&years=20&asset_class=stocks_sp500
    """
    return wealth_erosion_simulation(principal, years, asset_class, inflation_scenario)


@app.get("/v1/future-projection", tags=["Future Projections"])
def future_projection_endpoint(
    amount: float = Query(..., description="Current dollar amount", gt=0),
    years: int = Query(..., description="Years into the future", ge=1, le=50),
    inflation_rate: Optional[float] = Query(
        None,
        description="Custom inflation rate (leave blank for standard scenarios)",
        ge=0,
        le=0.50,
    ),
):
    """
    Project how inflation will erode purchasing power over time.
    Shows multiple scenarios: 2%, 3.1%, 5%, 8%.
    Example: /v1/future-projection?amount=1000000&years=10
    """
    return future_projection(amount, years, inflation_rate)


@app.get("/v1/million-shrinking", tags=["The Shrinking Million"])
def million_shrinking():
    """
    The signature endpoint: what does $1M from key years buy today?
    Shows the iconic "shrinking million" visual data.
    """
    key_years = [2000, 2005, 2010, 2013, 2015, 2020, 2025]
    results = []
    for yr in key_years:
        adj = inflation_adjust(1_000_000, yr, 2026)
        results.append({
            "year": yr,
            "million_then": 1_000_000,
            "worth_today": adj["adjusted_value"],
            "percent_change": adj["percent_change"],
            "cpi_then": adj["original_cpi"],
            "cpi_now": adj["target_cpi"],
        })

    # Current CPI note
    return {
        "title": "The Shrinking Million",
        "description": "What $1,000,000 from key years is worth in Apr 2026 dollars",
        "current_cpi": CURRENT_CPI,
        "current_month": CURRENT_MONTH,
        "data": results,
        "interpretation": (
            f"A 'Million Dollars' in 2013 is worth only "
            f"${results[3]['worth_today']:,.0f} today. "
            f"The million-dollar milestone keeps moving further away."
        ),
    }


@app.get("/v1/asset-classes", tags=["Reference"])
def list_asset_classes():
    """List all available asset classes and their return characteristics."""
    return {
        "asset_classes": {
            k: {kk: vv for kk, vv in v.items() if kk != "description"}
            for k, v in ASSET_CLASSES.items()
        }
    }


@app.get("/v1/inflation-categories", tags=["Reference"])
def list_inflation_categories():
    """List available inflation scenarios/categories."""
    return {
        "inflation_categories": CATEGORY_INFLATION,
        "note": "Annual inflation rates by category. Used for scenario projections.",
    }


