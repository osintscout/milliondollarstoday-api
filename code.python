# Category-specific inflation rates (approximate, 2024-2026)
CATEGORY_INFLATION = {
    "official_cpi": 0.031,        # Official CPI average
    "food": 0.045,                # Food inflation
    "housing": 0.050,             # Shelter/housing
    "healthcare": 0.060,          # Medical care
    "energy": 0.040,              # Energy
    "education": 0.055,           # Tuition/school
    "transportation": 0.035,      # Vehicles/transport
