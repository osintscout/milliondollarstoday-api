# =============================================================================
# HELPER FUNCTIONS
# =============================================================================

def get_cpi(year: int) -> float:
    """Get CPI value for a given year. Raises if not found."""
    cpi = CPI_DATA.get(year)
    if cpi is None:
        raise HTTPException(status_code=404, detail=f"No CPI data available for year {year}")
    return cpi


def inflation_adjust(amount: float, from_year: int, to_year: int) -> dict:
    """
    Calculate inflation-adjusted value from one year to another.
    Returns detailed breakdown.
    """
    cpi_from = get_cpi(from_year)
    cpi_to = get_cpi(to_year) if to_year in CPI_DATA else CURRENT_CPI

    ratio = cpi_to / cpi_from
    adjusted = round(amount * ratio, 2)
    raw_loss = round(amount - adjusted, 2)
    pct_change = round((ratio - 1) * 100, 2)

    return {
        "original_amount": amount,
        "original_year": from_year,
        "target_year": to_year,
        "original_cpi": cpi_from,
        "target_cpi": cpi_to,
        "adjusted_value": adjusted,
        "purchasing_power_lost": abs(raw_loss) if raw_loss < 0 else 0,
        "purchasing_power_gained": raw_loss if raw_loss > 0 else 0,
        "percent_change": pct_change,
        "ratio": round(ratio, 4),
        "interpretation": (
            f"${amount:,.0f} in {from_year} has the same purchasing power "
            f"as ${adjusted:,.0f} in {to_year} (based on official CPI)."
        ),
    }


def wealth_erosion_simulation(
    principal: float,
    years: int,
    asset_class: str,
    inflation_scenario: str = "official_cpi"
) -> dict:
    """
    Simulate nominal vs. real growth for an asset class over N years.
    """
    if asset_class not in ASSET_CLASSES:
        raise HTTPException(status_code=404, detail=f"Unknown asset class: {asset_class}")

    asset = ASSET_CLASSES[asset_class]
    if asset["nominal_return"] is None:
        raise HTTPException(status_code=400, detail=f"{asset['name']} has no return data (not an investment)")

    annual_inflation = CATEGORY_INFLATION.get(inflation_scenario, CATEGORY_INFLATION["official_cpi"])

    nominal_return = asset["nominal_return"]
    real_return = asset["real_return"]

    # Year-by-year projection
    yearly = []
    for y in range(1, years + 1):
        nominal_value = principal * ((1 + nominal_return) ** y)
        real_value = principal * ((1 + real_return) ** y)
        inflation_eroded = principal * ((1 + annual_inflation) ** y)
        yearly.append({
            "year": y,
            "nominal_value": round(nominal_value, 2),
            "real_value": round(real_value, 2),
            "inflation_eroded_purchasing_power": round(inflation_eroded, 2),
            "gain_over_inflation": round(nominal_value - inflation_eroded, 2),
        })

    final = yearly[-1]
    total_return_nominal = round(((final["nominal_value"] / principal) - 1) * 100, 2)
    total_return_real = round(((final["real_value"] / principal) - 1) * 100, 2)
    inflation_total = round(((final["inflation_eroded_purchasing_power"] / principal) - 1) * 100, 2)

    return {
        "principal": principal,
        "asset_class": asset["name"],
        "asset_class_id": asset_class,
        "years": years,
        "inflation_scenario": inflation_scenario,
        "inflation_rate": annual_inflation,
        "nominal_return_rate": nominal_return,
        "real_return_rate": real_return,
        "final_nominal_value": final["nominal_value"],
        "final_real_value": final["real_value"],
        "inflation_eroded_value_needed": final["inflation_eroded_purchasing_power"],
        "total_return_nominal_pct": total_return_nominal,
        "total_return_real_pct": total_return_real,
        "total_inflation_pct": inflation_total,
        "yearly": yearly,
        "interpretation": (
            f"If you invested ${principal:,.0f} in {asset['name']} for {years} years, "
            f"it would grow to ${final['nominal_value']:,.0f} nominally, "
            f"but after inflation it would be worth ${final['real_value']:,.0f} in today's dollars. "
            f"To maintain purchasing power, you'd need ${final['inflation_eroded_purchasing_power']:,.0f}."
        ),
    }


def future_projection(amount: float, years: int, inflation_rate: Optional[float] = None) -> dict:
    """
    Project what an amount will be worth in the future under various inflation scenarios.
    """
    scenarios = []

    rates_to_test = {}
    if inflation_rate is not None:
        rates_to_test["custom"] = inflation_rate
    else:
        rates_to_test = {
            "low (2% — Fed target)": 0.02,
            "moderate (3.1% — historical avg)": 0.031,
            "high (5% — persistent)": 0.05,
            "extreme (8% — 2022-style)": 0.08,
            "prepper_basket (7%)": 0.07,
        }

    for label, rate in rates_to_test.items():
        future_value_needed = amount * ((1 + rate) ** years)
        purchasing_power_remaining = amount / ((1 + rate) ** years)
        erosion = amount - purchasing_power_remaining

        scenarios.append({
            "scenario": label,
            "inflation_rate": rate,
            "future_value_needed": round(future_value_needed, 2),
            "purchasing_power_remaining": round(purchasing_power_remaining, 2),
            "value_eroded": round(erosion, 2),
            "percent_eroded": round((erosion / amount) * 100, 2),
        })

    return {
        "amount": amount,
        "years": years,
        "scenarios": scenarios,
        "interpretation": (
            f"${amount:,.0f} today may only be worth "
            f"${scenarios[1]['purchasing_power_remaining']:,.0f} "
            f"in {years} years at historical inflation rates."
        ),
    }


