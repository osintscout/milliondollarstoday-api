CURRENT_CPI = 333.02
CURRENT_MONTH = "Apr 2026"

ASSET_CLASSES = {
    "stocks_sp500": {"name": "S&P 500 (Stocks)", "nominal_return": 0.10, "real_return": 0.069, "volatility": 0.155},
    "bonds_10yr": {"name": "10-Year Treasury Bonds", "nominal_return": 0.053, "real_return": 0.022, "volatility": 0.070},
